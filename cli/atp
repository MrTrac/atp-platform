#!/usr/bin/env bash
set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(CDPATH='' cd -- "$(dirname -- "$SOURCE_PATH")" && pwd -P)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
done
ROOT_DIR="$(CDPATH='' cd -- "$(dirname -- "$SOURCE_PATH")/.." && pwd -P)"
CLI_PATH="./atp"
UNDERLYING_CLI_PATH="./cli/atp"

case "${1:-help}" in
  help|-h|--help)
    printf 'ATP v1.1 execution CLI (repo-local)\n'
    printf '\n'
    printf 'Usage:\n'
    printf '  %s <command> [args]\n' "$CLI_PATH"
    printf '\n'
    printf 'Bounded request-chain commands:\n'
    printf '  request-flow    Build the Slice 02 normalized request flow and single-AI package.\n'
    printf '  request-flow-multi  Build multiple Slice 02 request flows in explicit input order.\n'
    printf '  request-bundle  Build the Slice 03 reviewable output bundle from the same request path.\n'
    printf '  request-prompt  Build the Slice 04 one-shot AI-ready prompt artifact for manual handoff.\n'
    printf '  smoke-request-chain  Run the canonical repo-root smoke verification for the bounded chain.\n'
    printf '\n'
    printf 'Other commands:\n'
    printf '  run             Run ATP control-plane execution surfaces.\n'
    printf '  inspect         Inspect ATP configuration and repo-local state.\n'
    printf '  validate        Validate ATP repo-local contracts and inputs.\n'
    printf '\n'
    printf 'Canonical runnable example from repo root:\n'
    printf '  %s request-flow tests/fixtures/requests/sample_request_slice02.yaml\n' "$CLI_PATH"
    printf '  %s request-flow-multi tests/fixtures/requests/sample_request_slice02.yaml tests/fixtures/requests/sample_request_slice02_b.yaml\n' "$CLI_PATH"
    printf '  %s request-bundle tests/fixtures/requests/sample_request_slice02.yaml\n' "$CLI_PATH"
    printf '  %s request-prompt tests/fixtures/requests/sample_request_slice02.yaml\n' "$CLI_PATH"
    printf '\n'
    printf 'Canonical bounded-chain fixture policy:\n'
    printf '  tests/fixtures/requests/sample_request_slice02.yaml\n'
    printf '  Use this same fixture for help examples, repo-root smoke verification, and bounded happy-path checks.\n'
    printf '\n'
    printf 'Canonical smoke verification from repo root:\n'
    printf '  ./atp smoke-request-chain\n'
    printf '  ./atp smoke-request-chain tests/fixtures/requests/sample_request_slice02.yaml\n'
    printf '\n'
    printf 'Canonical verification contract from repo root:\n'
    printf '  verify-smoke  -> ./atp smoke-request-chain\n'
    printf '  verify-flow   -> ./atp request-flow tests/fixtures/requests/sample_request_slice02.yaml\n'
    printf '  verify-bundle -> ./atp request-bundle tests/fixtures/requests/sample_request_slice02.yaml\n'
    printf '  verify-prompt -> ./atp request-prompt tests/fixtures/requests/sample_request_slice02.yaml\n'
    printf '  Expected bounded result: all commands exit cleanly on the canonical fixture without changing execution scope.\n'
    printf '\n'
    printf 'Execution control boundaries:\n'
    printf '  control-mode  -> repo-local, human-gated, bounded single-AI execution only\n'
    printf '  auto-execute  -> disabled\n'
    printf '  release-gates -> merge main / push main / tag release remain unauthorized here\n'
    printf '\n'
    printf 'Canonical bounded operator path from repo root:\n'
    printf '  verify  -> ./atp smoke-request-chain\n'
    printf '  review  -> ./atp request-bundle tests/fixtures/requests/sample_request_slice02.yaml\n'
    printf '  handoff -> ./atp request-prompt tests/fixtures/requests/sample_request_slice02.yaml\n'
    printf '\n'
    printf 'Use `%s <command> -h` for command-specific help from repo root.\n' "$CLI_PATH"
    printf 'Underlying launcher path remains `%s`.\n' "$UNDERLYING_CLI_PATH"
    ;;
  run)
    exec python3 "$ROOT_DIR/cli/run.py" "${@:2}"
    ;;
  inspect)
    exec python3 "$ROOT_DIR/cli/inspect.py" "${@:2}"
    ;;
  validate)
    exec python3 "$ROOT_DIR/cli/validate.py" "${@:2}"
    ;;
  request-flow)
    exec python3 "$ROOT_DIR/cli/request_flow.py" "${@:2}"
    ;;
  request-flow-multi)
    exec python3 "$ROOT_DIR/cli/request_flow_multi.py" "${@:2}"
    ;;
  execution-session)
    exec python3 "$ROOT_DIR/cli/execution_session.py" "${@:2}"
    ;;
  request-bundle)
    exec python3 "$ROOT_DIR/cli/request_bundle.py" "${@:2}"
    ;;
  request-prompt)
    exec python3 "$ROOT_DIR/cli/request_prompt.py" "${@:2}"
    ;;
  smoke-request-chain)
    exec "$ROOT_DIR/scripts/smoke_request_chain.sh" "${@:2}"
    ;;
  *)
    printf 'Unknown command: %s\n' "${1}" >&2
    printf 'Run `%s help` for usage.\n' "$0" >&2
    exit 2
    ;;
esac
